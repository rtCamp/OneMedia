{
	"name": "onemedia",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/rtCamp/OneMedia.git"
	},
	"engines": {
		"node": ">=22.0.0",
		"npm": ">=10.0.0"
	},
	"files": [
		"build",
		"inc",
		"languages",
		"templates",
		"vendor",
		"readme.txt",
		"onemedia.php",
		"uninstall.php"
	],
	"dependencies": {
		"@wordpress/api-fetch": "^7.40.0",
		"@wordpress/components": "^30.9.0",
		"@wordpress/compose": "^7.40.0",
		"@wordpress/dom-ready": "^4.40.0",
		"@wordpress/element": "^6.40.0",
		"@wordpress/i18n": "^6.13.0",
		"@wordpress/icons": "^11.7.0",
		"@wordpress/primitives": "^4.40.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@babel/core": "^7.29.0",
		"@types/jest": "^29.5.14",
		"@types/react": "^18.3.28",
		"@types/react-dom": "^18.3.7",
		"@typescript-eslint/eslint-plugin": "^6.21.0",
		"@typescript-eslint/parser": "^6.21.0",
		"@wordpress/babel-preset-default": "^8.42.0",
		"@wordpress/e2e-test-utils-playwright": "^1.42.0",
		"@wordpress/browserslist-config": "^6.40.0",
		"@wordpress/env": "^11.1.0",
		"@wordpress/eslint-plugin": "^24.4.0",
		"@wordpress/prettier-config": "^4.41.0",
		"@wordpress/scripts": "^31.7.0",
		"@wordpress/stylelint-config": "^23.33.0",
		"browserslist": "^4.28.1",
		"cross-env": "^10.1.0",
		"css-minimizer-webpack-plugin": "^7.0.4",
		"eslint": "^8.57.1",
		"eslint-plugin-eslint-comments": "^3.2.0",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jest": "^28.14.0",
		"eslint-plugin-react-hooks": "^7.0.1",
		"globals": "^17.3.0",
		"jest-watch-typeahead": "^2.2.2",
		"lefthook": "^2.1.4",
		"lint-staged": "^16.4.0",
		"npm-run-all": "^4.1.5",
		"prettier": "npm:wp-prettier@^3",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3",
		"webpack-remove-empty-scripts": "^1.1.1"
	},
	"scripts": {
		"build:dev": "cross-env NODE_ENV=development npm-run-all 'build:!(dev|prod)'",
		"build:js": "wp-scripts build --config ./webpack.config.js",
		"build:prod": "npm run clean && cross-env NODE_ENV=production npm-run-all 'build:!(dev|prod)' && composer install --no-dev --optimize-autoloader",
		"clean": "rimraf build",
		"format": "wp-scripts format",
		"i18n:make-pot": "wp-env run cli --env-cwd=wp-content/plugins/$(basename \"$(pwd)\")/ -- wp i18n make-pot . ./languages/onemedia.pot --domain=onemedia --include='*.php,inc,src' --exclude='assets,build,node_modules,tests,vendor'",
		"i18n:make-json": "wp-env run cli --env-cwd=wp-content/plugins/$(basename \"$(pwd)\")/ -- wp i18n make-json languages/ --no-purge",
		"lint:css": "wp-scripts lint-style",
		"lint:css:fix": "wp-scripts lint-style --fix",
		"lint:js:fix": "wp-scripts lint-js --fix",
		"lint:js": "wp-scripts lint-js",
		"lint:js:types": "tsc --noEmit",
		"lint:php:fix": "composer run-script format",
		"lint:php:stan": "composer run-script phpstan",
		"lint:php": "composer run-script lint",
		"lint": "npm-run-all --parallel lint:*",
		"plugin-zip": "wp-scripts plugin-zip",
		"prepare": "lefthook install",
		"start:js": "wp-scripts start --config ./webpack.config.js",
		"start": "npm-run-all --parallel start:*",
		"test:e2e": "npm run test:e2e:prepare && wp-scripts test-playwright",
		"test:e2e:prepare": "npm run wp-env:test -- run cli wp plugin activate onemedia",
		"test:js": "wp-scripts test-unit-js",
		"test:js:watch": "wp-scripts test-unit-js --watch",
		"test:js:coverage": "wp-scripts test-unit-js --coverage",
		"test:php": "npm run wp-env:test -- run cli --env-cwd=wp-content/plugins/$(basename \"$(pwd)\")/ vendor/bin/phpunit -c phpunit.xml.dist",
		"wp-env": "wp-env",
		"wp-env:cli": "wp-env run cli --env-cwd=wp-content/plugins/$(basename \"$(pwd)\")/",
		"wp-env:child": "wp-env --config=.wp-env.child.json",
		"wp-env:test": "wp-env --config=.wp-env.test.json"
	},
	"overrides": {
		"@wordpress/env": "^11.1.0",
		"@babel/runtime": "^7.27.6",
		"fast-xml-parser": ">5.3.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"webpack-dev-server@<=5.2.0": ">=5.2.1",
		"serialize-javascript": ">=7.0.3",
		"@wp-playground/blueprints": {
			"ajv": ">=8.18.0"
		},
		"@wp-playground/tools": {
			"ajv": ">=8.18.0"
		},
		"@wp-playground/cli": {
			"ajv": ">=8.18.0"
		}
	}
}
