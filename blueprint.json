	},
	"features": {
		"networking": true
	},
	"steps": [
		{
			"step": "login",
			"username": "admin"
		},
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "url",
				"url": "https://github.com/rtCamp/OneMedia/releases/latest/download/onemedia.zip"
			},
			"options": {
				"activate": true
			}
		}
	]
}
