{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "OneMedia Demo",
		"description": "Centralized media sharing and synchronization across a multi-site WordPress network.",
		"author": "rtCamp",
		"categories": ["plugin", "media", "multisite", "enterprise"]
	},
	"landingPage": "/wp-admin/admin.php?page=onemedia-settings",
	"preferredVersions": {
		"php": "8.4",
