{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"noEmit": true,
		"types": ["jest", "node"]
	},
	"include": [
		"./**/*.ts",
		"./**/*.tsx",
		"../../assets/src/**/*.ts",
		"../../assets/src/**/*.tsx"
	],
	"exclude": ["../../node_modules", "../../build", "../../vendor"]
}
